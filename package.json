{
  "name": "odonts-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "commit": "cz"
  },
  "dependencies":{
    "next": "13.2.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "@stitches/react": "^1.2.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.3.0",
    "husky": "^8.0.2",
    "commitizen": "^4.2.6",
    "cz-conventional-changelog": "^3.3.0",
    "@types/node": "18.14.6",
    "@types/react": "18.0.28",
    "@types/react-dom": "18.0.11",
    "eslint": "8.35.0",
    "eslint-config-next": "13.2.3",
    "typescript": "4.9.5"
  },
  "husky": {
    "hooks": {
      "prepare-commit-msg": "exec < /dev/tty && npx cz --hook || true"
    }
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
